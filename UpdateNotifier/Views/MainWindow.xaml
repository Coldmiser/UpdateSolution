<!-- UpdateNotifier/Views/MainWindow.xaml
     The reboot-notification window.
     Design goals:
       • Always on top of all other windows.
       • Cannot be moved, minimised, or closed until the user picks an option.
       • Shows company logo, update summary, KB list, package list, and the snooze combo-box.
       • "Reboot Now" is pre-selected on every open.
-->
<Window x:Class="UpdateNotifier.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UpdateNotifier.ViewModels"
        xmlns:views="clr-namespace:UpdateNotifier.Views"
        Title="System Update — Reboot Required"
        Width="520" Height="Auto" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow">

    <!-- Prevent moving: handled in code-behind via WM_SYSCOMMAND -->

    <Window.Resources>
        <!-- Brand colours -->
        <Color x:Key="BrandBlue">#1E4D8C</Color>
        <Color x:Key="BrandDark">#0D1B2A</Color>
        <Color x:Key="BrandLight">#F0F4FA</Color>
        <SolidColorBrush x:Key="BrandBlueBrush"  Color="{StaticResource BrandBlue}"  />
        <SolidColorBrush x:Key="BrandDarkBrush"  Color="{StaticResource BrandDark}"  />
        <SolidColorBrush x:Key="BrandLightBrush" Color="{StaticResource BrandLight}" />

        <!-- Bool → Visibility converter used for KB and package list sections -->
        <views:BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource BrandBlueBrush}" />
            <Setter Property="Foreground"   Value="White" />
            <Setter Property="FontSize"     Value="14" />
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="Padding"      Value="24,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A6DD9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#163A6B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BrandLightBrush}">
        <Grid.RowDefinitions>
            <!-- Header bar with logo and title -->
            <RowDefinition Height="Auto" />
            <!-- Body content -->
            <RowDefinition Height="*" />
            <!-- Action strip (combo + button) -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Header ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BrandBlueBrush}"
                Padding="20,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Company logo.
                     Place your actual logo at UpdateNotifier/Resources/CompanyLogo.png.
                     The image is embedded as a resource in the single-file publish. -->
                <Image x:Name="CompanyLogoImage"
                       Height="40" Width="40"
                       Stretch="Uniform"
                       VerticalAlignment="Center"
                       Margin="0,0,14,0"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Capital Technology Group — System Update"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold" />
                    <TextBlock Text="Reboot Required"
                               Foreground="#B8CCE8"
                               FontSize="12" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ Body ════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Margin="28,22,28,10">

            <!-- Warning icon + main message -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock Text="⚠" FontSize="28" Foreground="#D97706"
                           VerticalAlignment="Top" Margin="0,2,10,0" />
                <TextBlock TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="{StaticResource BrandDarkBrush}">
                    <Run FontWeight="SemiBold"
                         Text="Updates have been applied to your system." />
                    <LineBreak />
                    <Run Text="A restart is required to complete the installation." />
                </TextBlock>
            </StackPanel>

            <!-- Divider -->
            <Separator Margin="0,0,0,14" />

            <!-- Update summary paragraph -->
            <TextBlock Text="{Binding UpdateSummary}"
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="#374151"
                       Margin="0,0,0,12" />

            <!-- KB Numbers (hidden when empty) -->
            <StackPanel Visibility="{Binding KbListVisible,
                                    Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,8">
                <TextBlock Text="Applied Windows patches:"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#6B7280" />
                <TextBlock Text="{Binding KbList}"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="#374151"
                           Margin="8,2,0,0" />
            </StackPanel>

            <!-- Package list (hidden when empty) -->
            <StackPanel Visibility="{Binding PackageListVisible,
                                    Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,8">
                <TextBlock Text="Updated applications:"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#6B7280" />
                <TextBlock Text="{Binding PackageList}"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="#374151"
                           Margin="8,2,0,0" />
            </StackPanel>

            <!-- Snooze note -->
            <TextBlock FontSize="12" Foreground="#9CA3AF"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Text="Select an option below.  Please note: the longest available snooze option is removed each time you defer." />
        </StackPanel>

        <!-- ═══ Action strip ════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                Padding="28,16">
            <DockPanel LastChildFill="False">

                <!-- Snooze combo-box -->
                <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                    <TextBlock Text="Choose an option:"
                               FontSize="11" Foreground="#6B7280"
                               Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableOptions}"
                              SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                              DisplayMemberPath="Label"
                              Width="230"
                              FontSize="13"
                              Height="34" />
                </StackPanel>

                <!-- Confirm button -->
                <Button DockPanel.Dock="Right"
                        Content="Confirm"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ConfirmCommand}"
                        VerticalAlignment="Bottom" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
